# ==========================================
# 🚀 SUPABASE CONFIGURATION
# ==========================================
# Find these in your Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# CRITICAL: Service Role Key bypasses RLS policies!
# Needed for Server Actions to insert embeddings natively. Add this to Vercel carefully.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ==========================================
# 🧠 GOOGLE AI STUDIO
# ==========================================
# Get your API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key

# ==========================================
# 💳 STRIPE MONETIZATION
# ==========================================
# Get these from your Stripe Dashboard -> Developers -> API Keys
STRIPE_SECRET_KEY=sk_test_...

# Run `stripe listen --forward-to localhost:3000/api/stripe/webhook` to get this locally
# Find this in Stripe Dashboard -> Webhooks for production
STRIPE_WEBHOOK_SECRET=whsec_...

# Create a Product & Price in Stripe -> Get the Price ID (starts with price_...)
STRIPE_PRO_PRICE_ID=price_...

# ==========================================
# 🌐 DEPLOYMENT
# ==========================================
# Change this to your Vercel production URL later (e.g., https://your-rag-app.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ==========================================
# 📦 FILE UPLOAD (UPLOADTHING - Optional)
# ==========================================
# Get these if using UploadThing from uploadingthing.com dashboard
UPLOADTHING_SECRET=your_uploadthing_secret
UPLOADTHING_APP_ID=your_uploadthing_app_id
